{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "API: Debug",
      "type": "debugpy",
      "request": "launch",
      "python": "${command:python.interpreterPath}",
      "program": "${workspaceFolder}/main.py",
      "envFile": "${workspaceFolder}/.env",
      "jinja": true
    },
    {
      "name": "API: Debug (Docker)",
      "type": "docker",
      "request": "launch",
      "preLaunchTask": "docker-build-run",
      "python": {
        "pathMappings": [
          {
            "localRoot": "${workspaceFolder}",
            "remoteRoot": "/app"
          }
        ],
        "projectType": "fastapi",
        "envFile": "${workspaceFolder}/.env",
        "jinja": true
      }
    },
    {
      "name": "API: Test",
      "type": "debugpy",
      "request": "launch",
      "python": "${command:python.interpreterPath}",
      "module": "pytest",
      "jinja": true
    },
    {
      "name": "API: Test (Docker)",
      "type": "docker",
      "request": "launch",
      "preLaunchTask": "docker-test-run",
      "python": {
        "pathMappings": [
          {
            "localRoot": "${workspaceFolder}",
            "remoteRoot": "/app"
          }
        ],
        "projectType": "general",
        "envFile": "${workspaceFolder}/.env",
        "jinja": true
      }
    }
  ]
}
